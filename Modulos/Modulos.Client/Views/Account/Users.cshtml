@model IEnumerable<Modulos.Client.Controllers.UserDto>
@{
    ViewData["Title"] = "Gestión de Usuarios";
}

<div class="container py-4">
    <div class="row mb-4 align-items-center">
        <div class="col">
            <h2 class="fw-bold text-primary mb-0">
                <i class="bi bi-people-fill me-2"></i>Gestión de Usuarios
            </h2>
            <p class="text-muted mb-0">Visualiza y administra todos los usuarios del sistema.</p>
        </div>
        <div class="col-auto">
            <a asp-action="Register" class="btn btn-primary-modern btn-modern px-4 py-2 rounded-pill shadow-sm border-0">
                <i class="bi bi-person-plus me-2"></i>Nuevo Usuario
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm rounded-3 mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm rounded-3 mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="glass-card border-0 animate-fade-in overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light bg-opacity-50">
                    <tr>
                        <th class="ps-4 py-3 text-muted small text-uppercase fw-bold">DNI</th>
                        <th class="py-3 text-muted small text-uppercase fw-bold">Usuario</th>
                        <th class="py-3 text-muted small text-uppercase fw-bold">Correo</th>
                        <th class="py-3 text-muted small text-uppercase fw-bold text-center">Estado Pass</th>
                        <th class="pe-4 py-3 text-muted small text-uppercase fw-bold text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
                    @foreach (var user in Model)
                    {
                        <tr class="user-row cursor-pointer" onclick="window.location.href='@Url.Action("UserProfile", new { id = user.Id })'">
                            <td class="ps-4 fw-medium text-primary">@user.DNI</td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="avatar-circle-sm bg-primary bg-opacity-10 text-primary me-3">
                                        @user.FirstName[0]@user.LastName[0]
                                    </div>
                                    <div>
                                        <div class="fw-bold text-dark">@user.FullName</div>
                                        <div class="small text-muted">@string.Join(", ", user.Roles)</div>
                                    </div>
                                </div>
                            </td>
                            <td>@user.Email</td>
                            <td class="text-center">
                                @if (user.MustChangePassword)
                                {
                                    <span class="badge rounded-pill bg-warning bg-opacity-10 text-warning px-3 py-2">
                                        <i class="bi bi-clock-history me-1"></i> Temporal
                                    </span>
                                }
                                else
                                {
                                    <span class="badge rounded-pill bg-success bg-opacity-10 text-success px-3 py-2">
                                        <i class="bi bi-check-lg me-1"></i> Cambiada
                                    </span>
                                }
                            </td>
                            <td class="pe-4 text-end" onclick="event.stopPropagation();">
                                <form asp-action="ResetPassword" asp-route-id="@user.Id" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-outline-primary rounded-pill px-3" 
                                            onclick="return confirm('¿Está seguro de reiniciar la contraseña de @user.FullName?')">
                                        <i class="bi bi-shield-lock me-1"></i> Reiniciar
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .avatar-circle-sm {
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        font-weight: 600;
        font-size: 0.85rem;
    }
    .user-row {
        transition: all 0.2s ease;
    }
    .user-row:hover {
        background-color: rgba(79, 70, 229, 0.03) !important;
        transform: translateY(-1px);
    }
    .cursor-pointer {
        cursor: pointer;
    }
</style>
