@{
    ViewData["Title"] = "Login";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5 col-lg-4">
            <div class="glass-card p-4 p-md-5 animate-fade-in shadow-lg">
                <div class="text-center mb-4">
                    <div class="bg-primary bg-opacity-10 d-inline-block p-3 rounded-circle mb-3">
                        <i class="bi bi-shield-lock-fill text-primary fs-1"></i>
                    </div>
                    <h2 class="fw-bold text-primary">Bienvenido</h2>
                    <p class="text-muted small">Ingresa tus credenciales para continuar</p>
                </div>

                <form asp-action="Login" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                    
                    <div class="mb-3">
                        <label for="inputEmail" class="form-label small fw-semibold text-secondary">Correo Electrónico</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0 rounded-start-pill ps-3">
                                <i class="bi bi-envelope text-muted"></i>
                            </span>
                            <input type="email" name="email" class="form-control form-control-modern border-start-0 rounded-end-pill" id="inputEmail" placeholder="ejemplo@correo.com" required />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="inputPassword" class="form-label small fw-semibold text-secondary">Contraseña</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0 rounded-start-pill ps-3">
                                <i class="bi bi-lock text-muted"></i>
                            </span>
                            <input type="password" name="password" class="form-control form-control-modern border-start-0 rounded-end-pill" id="inputPassword" placeholder="••••••••" required />
                        </div>
                        <div class="form-check mt-2 ms-1">
                            <input class="form-check-input shadow-none" type="checkbox" id="togglePassword">
                            <label class="form-check-label small text-muted cursor-pointer" for="togglePassword">
                                Mostrar contraseña
                            </label>
                        </div>
                    </div>

                    <div class="form-check mb-4 ms-1">
                        <input class="form-check-input shadow-none" type="checkbox" name="rememberMe" id="inputRememberMe" value="true" />
                        <label class="form-check-label text-muted small" for="inputRememberMe">Mantener sesión iniciada</label>
                    </div>

                    <button type="submit" class="btn btn-primary-modern btn-modern w-100 py-3 shadow-sm border-0">
                        Entrar al Sistema <i class="bi bi-arrow-right ms-2"></i>
                    </button>
                </form>
            </div>
            
            <p class="text-center mt-4 text-muted small">
                ¿Problemas para ingresar? <a href="#" class="text-decoration-none fw-semibold">Contactar Soporte</a>
            </p>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('togglePassword').addEventListener('change', function() {
            const passwordInput = document.getElementById('inputPassword');
            passwordInput.type = this.checked ? 'text' : 'password';
        });
    </script>
}

<style>
    body {
        background: radial-gradient(circle at top right, #f8fafc, #e2e8f0);
        min-height: 100vh;
    }
    .cursor-pointer { cursor: pointer; }
    .rounded-pill { border-radius: 50rem !important; }
    .rounded-start-pill { border-top-left-radius: 50rem !important; border-bottom-left-radius: 50rem !important; }
    .rounded-end-pill { border-top-right-radius: 50rem !important; border-bottom-right-radius: 50rem !important; }
</style>
