@{
    ViewData["Title"] = "Cambiar Contraseña";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="glass-card animate-fade-in border-0 overflow-hidden shadow-lg">
                <div class="bg-warning p-4 text-dark d-flex align-items-center">
                    <div class="bg-white bg-opacity-50 rounded-circle p-2 me-3 shadow-sm">
                        <i class="bi bi-shield-lock-fill fs-4"></i>
                    </div>
                    <div>
                        <h4 class="fw-bold mb-0">Cambio Obligatorio</h4>
                        <p class="mb-0 opacity-75 small">Debes actualizar tu contraseña temporal</p>
                    </div>
                </div>

                <div class="card-body p-4 p-md-5 bg-white">
                    <form asp-action="ChangePassword" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-4 small p-3 bg-danger bg-opacity-10 rounded"></div>
                        
                        <div class="mb-4">
                            <label class="form-label small fw-bold text-secondary">Contraseña Actual</label>
                            <div class="password-toggle-group">
                                <input type="password" name="currentPassword" id="currentPassword" class="form-control form-control-modern" placeholder="Tu contraseña temporal" required />
                                <button type="button" class="password-toggle-btn" onclick="togglePassword('currentPassword', this)">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                            <span class="text-danger small" data-valmsg-for="currentPassword"></span>
                        </div>

                        <div class="mb-4">
                            <label class="form-label small fw-bold text-secondary">Nueva Contraseña</label>
                            <div class="password-toggle-group">
                                <input type="password" name="newPassword" id="newPassword" class="form-control form-control-modern" placeholder="Mínimo 6 caracteres" required />
                                <button type="button" class="password-toggle-btn" onclick="togglePassword('newPassword', this)">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                            <span class="text-danger small" data-valmsg-for="newPassword"></span>
                        </div>

                        <div class="mb-5">
                            <label class="form-label small fw-bold text-secondary">Confirmar Nueva Contraseña</label>
                            <div class="password-toggle-group">
                                <input type="password" name="confirmPassword" id="confirmPassword" class="form-control form-control-modern" 
                                       placeholder="Repite la nueva contraseña" required onpaste="return false;" oncontextmenu="return false;" />
                                <button type="button" class="password-toggle-btn" onclick="togglePassword('confirmPassword', this)">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                            <span class="text-danger small" data-valmsg-for="confirmPassword"></span>
                            <div class="form-text small mt-1"><i class="bi bi-info-circle me-1"></i> Por seguridad, el ingreso debe ser manual.</div>
                        </div>

                        <button type="submit" class="btn btn-primary-modern btn-modern w-100 py-3 shadow-sm border-0">
                            <i class="bi bi-arrow-repeat me-2"></i> Actualizar y Continuar
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
}
