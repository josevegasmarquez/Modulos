@model Modulos.Client.Controllers.UserDto
@{
    ViewData["Title"] = "Editar Perfil";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="glass-card animate-fade-in border-0 overflow-hidden">
                <div class="bg-primary p-4 text-white">
                    <h3 class="fw-bold mb-0"><i class="bi bi-pencil-square me-2"></i>Editar Mis Datos</h3>
                    <p class="mb-0 opacity-75 small">Mantén tu información actualizada</p>
                </div>
                
                <div class="card-body p-4 p-md-5 bg-white">
                    <form asp-action="EditProfile" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-4 small p-3 bg-danger bg-opacity-10 rounded"></div>
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="Email" />
                        <input type="hidden" asp-for="DNI" />

                        <div class="row g-4">
                            <!-- Nombres y Apellidos -->
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-secondary">Nombres</label>
                                <input asp-for="FirstName" class="form-control form-control-modern" required />
                                <span asp-validation-for="FirstName" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-secondary">Apellidos</label>
                                <input asp-for="LastName" class="form-control form-control-modern" required />
                                <span asp-validation-for="LastName" class="text-danger small"></span>
                            </div>

                            <!-- Fecha Nacimiento y Género -->
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-secondary">Fecha de Nacimiento</label>
                                <input asp-for="DateOfBirth" type="date" class="form-control form-control-modern" required />
                                <span asp-validation-for="DateOfBirth" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-secondary">Género</label>
                                <select asp-for="Genero" class="form-select form-control-modern" required>
                                    <option value="0">Masculino</option>
                                    <option value="1">Femenino</option>
                                    <option value="2">Otro</option>
                                    <option value="3">Prefiero no decirlo</option>
                                </select>
                                <span asp-validation-for="Genero" class="text-danger small"></span>
                            </div>

                            <!-- Teléfono y Dirección -->
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-secondary">Teléfono</label>
                                <input asp-for="PhoneNumber" class="form-control form-control-modern" />
                                <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-secondary">Dirección</label>
                                <input asp-for="Address" class="form-control form-control-modern" />
                                <span asp-validation-for="Address" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-5 pt-4 border-top">
                            <a asp-action="Profile" class="btn btn-outline-secondary px-4 rounded-pill">
                                <i class="bi bi-x-circle me-1"></i> Cancelar
                            </a>
                            <button type="submit" class="btn btn-primary-modern btn-modern px-5 shadow-sm rounded-pill border-0">
                                <i class="bi bi-check2-circle me-1"></i> Guardar Cambios
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
}
