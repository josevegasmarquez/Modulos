@model Modulos.Client.Controllers.RegisterRequest
@{
    ViewData["Title"] = "Registrar Usuario";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="glass-card animate-fade-in border-0 overflow-hidden">
                <div class="bg-primary p-4 text-white d-flex align-items-center">
                    <div class="bg-white bg-opacity-25 rounded-circle p-2 me-3">
                        <i class="bi bi-person-plus-fill fs-4"></i>
                    </div>
                    <div>
                        <h3 class="fw-bold mb-0">Registrar Nuevo Usuario</h3>
                        <p class="mb-0 opacity-75 small">Modulo de administración de usuarios</p>
                    </div>
                </div>

                <div class="card-body p-4 p-md-5 bg-white">
                    @if (ViewBag.Message != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show rounded-pill px-4" role="alert">
                            <i class="bi bi-check-circle-fill me-2"></i> @ViewBag.Message
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <form asp-action="Register" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-4 small p-3 bg-danger bg-opacity-10 rounded"></div>
                        
                        <h5 class="text-primary fw-bold mb-4 border-bottom pb-2">Datos Personales</h5>
                        <div class="row g-4 mb-5">
                            <div class="col-md-4">
                                <label class="form-label small fw-bold text-secondary">Nombres</label>
                                <input asp-for="Nombres" class="form-control form-control-modern" placeholder="Ej. Juan" required />
                                <span asp-validation-for="Nombres" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small fw-bold text-secondary">Apellidos</label>
                                <input asp-for="Apellidos" class="form-control form-control-modern" placeholder="Ej. Pérez" required />
                                <span asp-validation-for="Apellidos" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small fw-bold text-secondary">DNI</label>
                                <input asp-for="DNI" class="form-control form-control-modern" placeholder="8 dígitos" required maxlength="8" />
                                <span asp-validation-for="DNI" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small fw-bold text-secondary">Fecha de Nacimiento</label>
                                <input asp-for="FechaNacimiento" type="date" class="form-control form-control-modern" required />
                                <span asp-validation-for="FechaNacimiento" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small fw-bold text-secondary">Género</label>
                                <select asp-for="Genero" class="form-select form-control-modern" required>
                                    <option value="0">Masculino</option>
                                    <option value="1">Femenino</option>
                                    <option value="2">Otro</option>
                                    <option value="3">Prefiero no decirlo</option>
                                </select>
                                <span asp-validation-for="Genero" class="text-danger small"></span>
                            </div>
                        </div>

                        <h5 class="text-primary fw-bold mb-4 border-bottom pb-2">Acceso y Seguridad</h5>
                        <div class="row g-4 mb-5">
                            <div class="col-md-4">
                                <label class="form-label small fw-bold text-secondary">Correo Electrónico</label>
                                <input asp-for="Email" type="email" class="form-control form-control-modern" placeholder="usuario@modulos.com" required />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small fw-bold text-secondary">Contraseña Temporal</label>
                                <div class="password-toggle-group">
                                    <input asp-for="Password" type="password" class="form-control form-control-modern" placeholder="Mín. 6 caracteres" required />
                                    <button type="button" class="password-toggle-btn" onclick="togglePassword('Password', this)">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                </div>
                                <span asp-validation-for="Password" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4">
                                <div class="form-floating mb-3">
                                    <select asp-for="Role" class="form-select border-0 shadow-sm rounded-3">
                                        <option value="">Seleccione un Rol</option>
                                        @if (ViewBag.Roles != null)
                                        {
                                            foreach (var role in (List<string>)ViewBag.Roles)
                                            {
                                                <option value="@role">@role</option>
                                            }
                                        }
                                    </select>
                                    <label asp-for="Role" class="text-muted"><i class="bi bi-shield-lock-fill me-2"></i>Rol</label>
                                    <span asp-validation-for="Role" class="text-danger small position-absolute mt-1"></span>
                                </div>
                            </div>
                        </div>

                        <h5 class="text-primary fw-bold mb-4 border-bottom pb-2">Contacto</h5>
                        <div class="row g-4">
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-secondary">Teléfono</label>
                                <input asp-for="PhoneNumber" class="form-control form-control-modern" placeholder="Opcional" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-secondary">Dirección</label>
                                <input asp-for="Direccion" class="form-control form-control-modern" placeholder="Opcional" />
                            </div>
                        </div>

                        <div class="d-flex justify-content-end align-items-center mt-5 pt-4 border-top">
                            <button type="submit" class="btn btn-primary-modern btn-modern px-5 shadow-sm rounded-pill border-0">
                                <i class="bi bi-person-check me-2"></i> Crear Usuario
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
}
